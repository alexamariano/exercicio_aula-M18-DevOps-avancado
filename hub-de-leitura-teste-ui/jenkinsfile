pipeline {
    agent any
    tools { nodejs "nodejs" }
    
    environment {
        // Cache em um caminho curto para fugir do limite do Windows
        CYPRESS_CACHE_FOLDER = "C:\\CypressCache"
        CI = '1' 
    }

    stages {
        stage("Preparar Aplicação (Backend)") {
            steps {
                dir('hub-de-leitura-integrado') {
                    bat 'call npm install'
                    bat 'start /B npm start'
                }
            }
        }

        stage("Instalar dependências de teste") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    bat 'call npm config set ignore-scripts false'
                    bat 'call npm install'
                }
            }
        }

        stage('Executar testes') {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    // Força a instalação na nova pasta curta e verifica se deu certo
                    bat 'call npx cypress install --force'
                    bat 'call npx cypress verify'
                    
                    // Executa os testes
                    bat 'call npx cypress run'
                }
            }
        }
    }

    post {
        always {
            dir('hub-de-leitura-teste-ui') {
                archiveArtifacts artifacts: 'cypress/screenshots/**/*.*,cypress/videos/**/*.*', allowEmptyArchive: true
            }
            bat 'taskkill /F /IM node.exe || exit 0' 
        }
    }
}