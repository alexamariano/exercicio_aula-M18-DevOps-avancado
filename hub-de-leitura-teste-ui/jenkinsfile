pipeline {
    agent any
    tools { nodejs "nodejs" }

    environment {
        CYPRESS_CACHE_FOLDER = "C:\\CypressCache"
        CI = '1' 
    }

    stages {
        stage("Preparar Aplicação") {
            steps {
                dir('..\\hub-de-leitura-integrado') {
                    bat '''
                        call npm install
                        start /B npm start
                    '''
                }
            }
        }

        stage("Instalar dependencias de teste") {
            steps {
                bat 'call npm install'
            }
        }

        stage('Executar os testes automatizados') {
            steps {
                bat '''
                    call npx cypress install --force
                    call npm test
                '''
            }
        }
    }

    post {
        always {
            // Se houver screenshots ou vídeos, o Jenkins vai arquivar
            archiveArtifacts artifacts: 'cypress/screenshots/**/*.*,cypress/videos/**/*.*', allowEmptyArchive: true
            bat 'taskkill /F /IM node.exe || exit 0'
        }
    }
}