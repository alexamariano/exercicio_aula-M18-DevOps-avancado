pipeline {
    agent any
    tools { nodejs "nodejs" }
    
    environment {
        // Volta o cache para dentro do projeto
        CYPRESS_CACHE_FOLDER = "${WORKSPACE}\\cypress_cache"
        //Redireciona a pasta temporária do Windows para o Workspace
        TEMP = "${WORKSPACE}\\temp"
        TMP = "${WORKSPACE}\\temp"
        CI = '1' 
    }

    stages {
        stage("Preparar Ambiente e Backend") {
            steps {
                // Cria a pasta temporária do Jenkins antes de qualquer coisa
                bat 'if not exist "%WORKSPACE%\\temp" mkdir "%WORKSPACE%\\temp"'
                
                dir('hub-de-leitura-integrado') {
                    bat 'call npm install'
                    bat 'start /B npm start'
                }
            }
        }

        stage("Instalar dependências de teste") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    bat 'call npm install'
                }
            }
        }

        stage('Executar testes') {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    // Agora o extrator do Cypress terá permissão total para descompactar o arquivo .exe
                    bat 'call npx cypress install --force'
                    bat 'call npx cypress verify'
                    
                    // Executa os testes
                    bat 'call npx cypress run'
                }
            }
        }
    }

    post {
        always {
            dir('hub-de-leitura-teste-ui') {
                archiveArtifacts artifacts: 'cypress/screenshots/**/*.*,cypress/videos/**/*.*', allowEmptyArchive: true
            }
            bat 'taskkill /F /IM node.exe || exit 0' 
        }
    }
}